DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/ewondo_learning"

JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
CERTIFICATE_VERIFY_URL=http://localhost:3000/api/certificates/verify

PORT=3000

# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=NdaMinkoaba

# --- Google / Facebook sign-in (see README "OAuth sign-in setup") ---
# Comma-separated list of every OAuth Client ID you create (Web, Android, iOS) —
# verifyIdToken() accepts any of these as a valid audience. Leave empty to
# disable Google sign-in (POST /auth/google returns a clean 401 until set).
GOOGLE_CLIENT_ID=

# Facebook App ID/Secret from developers.facebook.com. Leave empty to disable
# Facebook sign-in (POST /auth/facebook returns a clean 401 until set).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
