<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 9+ (targetSdk 28+) blocks plaintext HTTP by default. The backend
  runs as a local NestJS dev server (no HTTPS in this setup yet), so
  cleartext must be explicitly allowed for the dev machine's LAN IP that
  the app's --dart-define=API_BASE_URL points at during testing. Update the
  IP below if the dev machine's address changes.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.100.152</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
